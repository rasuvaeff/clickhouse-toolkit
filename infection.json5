{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "php://stderr",
        "summary": "build/infection-summary.log"
    },
    // 95 is the honest floor. The remaining survivors are equivalent mutants:
    //  - `mkdir` / `file_put_contents` / `file_get_contents` failure branches need
    //    a read-only filesystem to exercise and are equivalent in practice;
    //  - `(int)` / `(string)` casts on JSON values and Symfony `getArgument()`
    //    are redundant (PHP auto-coerces);
    //  - `glob() === false` checks are unreachable (glob returns `[]`);
    //  - `sort()` after `glob()` is redundant (glob already sorts);
    //  - `match (true)` subject and wall-clock polling (`microtime`/`usleep`)
    //    are untestable by design (PCOV quirk / timing flakiness).
    "minMsi": 95,
    "testFramework": "testo",
    "mutators": {
        "@default": true
    }
}
